# Copy to .env.local for local dev, or set these in your host (Vercel / Cloudflare Pages).
# All are optional. Values are read at BUILD time (static export), so rebuild after changing.

# Canonical site URL for canonical/hreflang/OG/sitemap. If unset, it falls back to the
# deployment URL (Vercel/Cloudflare) and finally to https://splitwhom.com.
# NEXT_PUBLIC_SITE_URL=https://splitwhom.com

# Google Analytics 4 Measurement ID. Analytics only load when this is set.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense client id. The loader + verification meta + ads.txt only appear
# when this is set. Requires a custom domain + AdSense approval before ads show.
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# AdSense ad-unit slot id for the home-page unit (below the landing sections).
# The unit renders nothing until this is set, so it stays inert before approval.
# After approval: create the unit in the AdSense dashboard, paste its slot id here,
# and rebuild/redeploy — no code change needed.
# NEXT_PUBLIC_ADSENSE_SLOT_HOME=1234567890
